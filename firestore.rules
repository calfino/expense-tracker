# Paste these rules in:
# Firebase Console → Firestore Database → Rules tab → Publish

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /families/{familyId} {

      // CREATE: allowed if the authenticated user is setting themselves as a member
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;

      // READ / UPDATE / DELETE: only existing members
      allow read, update, delete: if request.auth != null
        && request.auth.uid in resource.data.members;

      // Transactions subcollection
      match /transactions/{txId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
      }

      // Budgets subcollection
      match /budgets/{month} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
      }
    }
  }
}
