# Paste these rules in:
# Firebase Console → Firestore Database → Rules tab → Publish

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /families/{familyId} {

      // CREATE: allowed if the authenticated user is setting themselves as a member
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;

      // GET: allow any authenticated user to fetch a family by ID (needed for invite code validation)
      allow get: if request.auth != null;
      
      // LIST: only existing members
      allow list: if request.auth != null
        && request.auth.uid in resource.data.members;

      // UPDATE / DELETE: allow if existing member, OR if adding themselves (joining)
      allow update: if request.auth != null
        && (
             request.auth.uid in resource.data.members 
             || 
             request.auth.uid in request.resource.data.members
           );
           
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.members;

      // Transactions subcollection
      match /transactions/{txId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
      }

      // Budgets subcollection
      match /budgets/{month} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
      }
    }
  }
}
